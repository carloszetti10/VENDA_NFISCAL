begin

end;



procedure TUsuarioService.IInserirUsuario(Usuario: TUsuarioModel; listaPermi: TList<Integer>);
begin
  //verificar se tem Login com esse nome

   FConexao.StartTransaction;
  try
    // 1. insere usußrio
    FUsuarioDAO.Insert(Usuario);

    // 2. insere permiss§es
    FUsuarioDAO.SalvarPermissoes(Usuario.Id, listaPermi);

    // 3. tudo deu certo
    FConexao.Commit;

  except
    on E: Exception do
    begin
      FConexao.Rollback;
      raise Exception.Create('Erro ao inserir usußrio: ' + E.Message);
    end;
end;

end.
