unit uVendaDao;
interface
uses
  IVendaDAO, uVendaModel, System.SysUtils, System.Classes, Data.DB, ZAbstractRODataset,
  ZAbstractDataset, ZDataset, ZAbstractConnection, ZConnection, uException,
  System.Generics.Collections, uUsuarioModel;
type
  TVendaDao = class(TInterfacedObject, IVendaDAOO)
    private
      FConexao : TZConnection;
    public
      function Insert(IdUsuario: Integer): Integer;
      function  FindByID(cod: Integer): TVendaModel;
      procedure ListarPorNomeTela(Q: TZQuery; Nome: string);
      Constructor Create(Conn:TZConnection);

      {===== ATUALIZAЫO ====}
      function UpdateCliente(IdCliente: Integer; IdVenda: Integer): Integer;
      function UpdateFuncionario(IdFunc: Integer; IdVenda: Integer): Integer;
      {===== CANCELAR VENDA ====}
      procedure UpdateStatus(IdVenda: Integer; status: TStatusVenda);
  end;


implementation

{ TVendaDao }


{ ================== CONSTRUTOR ================== }
constructor TVendaDao.Create(Conn: TZConnection);
begin
  inherited Create;
  FConexao := Conn;
end;

function TVendaDao.FindByID(cod: Integer): TVendaModel;
begin

end;

{ ================== INICIAR VENDA ================== }
function TVendaDao.Insert(IdUsuario: Integer): Integer;
var
  Q: TZQuery;
begin
  Q:= TZQuery.Create(nil);
  try
    try
      Q.Connection := FConexao;

      Q.SQL.Text := 'INSERT INTO VENDA (ID_USUARIO) VALUES (:ID) RETURNING ID_VENDA';
      Q.ParamByName('ID').AsInteger   := IdUsuario;
      Q.Open;

      Result := Q.FieldByName('ID_VENDA').AsInteger;
    except
      on E: EDatabaseError do
        raise EInfraException.Create('Erro ao iniciar venda' + E.Message);
    end;
  finally
    Q.Free;
  end;

end;


{ ================== LISTAR PRODUTOS ================== }
procedure TVendaDao.ListarPorNomeTela(Q: TZQuery; Nome: string);
begin

end;


{ ================== ATUALIZAR VENDA CLIENTE/VENDEDOR ================== }
function TVendaDao.UpdateCliente(IdCliente: Integer; IdVenda: Integer): Integer;
var
  Q: TZQuery;
begin
  Q:= TZQuery.Create(nil);
  try
    try
      Q.Connection := FConexao;

      Q.SQL.Text := 'UPDATE VENDA SET ID_CLIENTE = :ID_CLI WHERE ID_VENDA = :ID_VENDA ' +
        'RETURNING ID_CLIENTE';
      Q.ParamByName('ID_CLI').AsInteger   := IdCliente;
      Q.ParamByName('ID_VENDA').AsInteger   := IdVenda;
      Q.Open;

      Result := Q.FieldByName('ID_CLIENTE').AsInteger;
    except
      on E: EDatabaseError do
        raise EInfraException.Create('Erro ao adicionar o cliente: ' + E.Message);
    end;
  finally
    Q.Free;
  end;
end;
function TVendaDao.UpdateFuncionario(IdFunc: Integer; IdVenda: Integer): Integer;
var
  Q: TZQuery;
begin
  Q:= TZQuery.Create(nil);
  try
    try
      Q.Connection := FConexao;

      Q.SQL.Text := 'UPDATE VENDA SET ID_VENDEDOR = :ID_FUNC WHERE ID_VENDA = :ID_VENDA ' +
        'RETURNING ID_CLIENTE';
      Q.ParamByName('ID_FUNC').AsInteger   := IdFunc;
      Q.ParamByName('ID_VENDA').AsInteger := IdVenda;
      Q.Open;

      Result := Q.FieldByName('ID_ID_VENDEDOR').AsInteger;
    except
      on E: EDatabaseError do
        raise EInfraException.Create('Erro ao adicionar vendedor: ' + E.Message);
    end;
  finally
    Q.Free;
  end;

end;

