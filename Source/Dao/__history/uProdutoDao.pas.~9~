procedure TProdutoDao.ListarPorNomeTela(Q: TZQuery; Nome: string);
begin
  Q.Close;
  Q.Connection := FConexao;

  Q.SQL.Text :=
    'SELECT * FROM PRODUTO WHERE NOME LIKE :NOME AND ATIVO = 1';

  Q.ParamByName('NOME').AsString := '%' + Nome + '%';
  Q.Open;
end;

end.
