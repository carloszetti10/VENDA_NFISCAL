unit uVendaDavUI;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.StdCtrls, Vcl.Buttons,
  Vcl.ComCtrls, Data.DB, Vcl.Grids, Vcl.DBGrids;

type
  TfrmVendaDav = class(TForm)
    Panel1: TPanel;
    Panel2: TPanel;
    Panel3: TPanel;
    Edit1: TEdit;
    Label1: TLabel;
    dtmEmisao: TDateTimePicker;
    Label2: TLabel;
    Label3: TLabel;
    edtCliente: TEdit;
    Label4: TLabel;
    Label5: TLabel;
    Label6: TLabel;
    Panel4: TPanel;
    Label7: TLabel;
    edtPesquisa: TEdit;
    edtQuantidade: TEdit;
    Label8: TLabel;
    Label9: TLabel;
    edtValorUnitarioProd: TEdit;
    edtBruto: TEdit;
    edtDesconto: TEdit;
    edtLiquido: TEdit;
    Label10: TLabel;
    Label11: TLabel;
    Label12: TLabel;
    edtVendedor: TEdit;
    btnNovo: TBitBtn;
    BitBtn1: TBitBtn;
    BitBtn2: TBitBtn;
    Panel5: TPanel;
    Panel6: TPanel;
    painelEstoque: TPanel;
    painelVenda: TPanel;
    DBGrid1: TDBGrid;
    DBGrid2: TDBGrid;
    Panel7: TPanel;
    Panel8: TPanel;
    procedure FormShow(Sender: TObject);
  private
    { Private declarations }
  public
    procedure AlternaPainel(PainelVisivel: TPanel; PainelOculto: TPanel);
  end;

var
  frmVendaDav: TfrmVendaDav;

implementation

{$R *.dfm}

//---------Manipular tabela que aparece----------------------
procedure TfrmVendaDav.AlternaPainel(PainelVisivel, PainelOculto: TPanel);
begin
   PainelVisivel.Align:= alClient;
   PainelVisivel.Visible:= true;
   PainelOculto.Visible:= False;
end;

procedure TfrmVendaDav.FormShow(Sender: TObject);
begin
  AlternaPainel(painelEstoque, painelVenda);
end;


end.
