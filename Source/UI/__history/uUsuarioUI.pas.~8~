unit uUsuarioUI;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, uTelaBaseCadastroUI, Data.DB, Vcl.Grids,
  Vcl.DBGrids, Vcl.StdCtrls, Vcl.Buttons, Vcl.Mask, Vcl.ExtCtrls, Vcl.ComCtrls,
  Vcl.CheckLst, System.Generics.Collections, uUsuarioModel, uValidarCampo, iUsuarioService;

type
  TTfrmCadastroUsuario = class(TfrmTelaBaseCadastro)
    GroupBox1: TGroupBox;
    Label1: TLabel;
    mskLogin: TMaskEdit;
    mskSenha: TMaskEdit;
    mskFuncionario: TMaskEdit;
    BitBtn1: TBitBtn;
    GroupBox2: TGroupBox;
    clbPermissoes: TCheckListBox;
  private
    FService: IUsuarioServiceInterface;
    procedure Inserir; override;
  public
    procedure PrencherPermissao;
    procedure MarcarPermissoes(Lista: TList<Integer>);
    function PegarPermissoesMarcadas: TList<Integer>;
    constructor Create(AOwner: TComponent; AService: IUsuarioServiceInterface);
  end;

var
  TfrmCadastroUsuario: TTfrmCadastroUsuario;

implementation

{$R *.dfm}



{ TTfrmCadastroUsuario }

constructor TTfrmCadastroUsuario.Create(AOwner: TComponent; AService: IUsuarioServiceInterface);
begin
  FService:= AService;
  PrencherPermissao;
end;

procedure TTfrmCadastroUsuario.Inserir;
  var
  Usuario: TUsuarioModel;
  Lista: TList<Integer>;
begin
  inherited;
  TValidarCampos.ValidarCampoVazio(mskLogin, 'Login');
  TValidarCampos.ValidarCampoVazio(mskSenha, 'Senha');

  Lista:= PegarPermissoesMarcadas;
  Usuario:= TUsuarioModel.Create;
  try
    Usuario.Login := mskLogin.Text;
    Usuario.Senha:= mskSenha.Text;
    //pegar o id do funcionario depois
    FService.IInserirUsuario(Usuario);
    ShowMessage('Cadastro realizado!');
    ControlarBotoes(true);
  finally
     Usuario.Free;
     Lista.Free;
  end
end;

procedure TTfrmCadastroUsuario.MarcarPermissoes(Lista: TList<Integer>);
var
  i: Integer;
  IdPermissao: Integer;
begin
  // limpa
  for i := 0 to clbPermissoes.Count - 1 do
    clbPermissoes.Checked[i] := False;

  // percorre lista do banco
  for IdPermissao in Lista do
  begin
    // procura no checklist
    for i := 0 to clbPermissoes.Count - 1 do
    begin
      if Integer(clbPermissoes.Items.Objects[i]) = IdPermissao then
      begin
        clbPermissoes.Checked[i] := True;
        Break;
      end;
    end;
  end;
end;

function TTfrmCadastroUsuario.PegarPermissoesMarcadas: TList<Integer>;
var
  i: Integer;
begin
  Result := TList<Integer>.Create;

  for i := 0 to clbPermissoes.Count - 1 do
  begin
    if clbPermissoes.Checked[i] then
      Result.Add(Integer(clbPermissoes.Items.Objects[i]));
  end;
end;

procedure TTfrmCadastroUsuario.PrencherPermissao;
begin
  clbPermissoes.Items.Clear;

  clbPermissoes.Items.AddObject('CADASTRAR CLIENTE', TObject(1));
  clbPermissoes.Items.AddObject('CADASTRAR PRODUTO', TObject(2));
  clbPermissoes.Items.AddObject('CADASTRAR FUNCIONARIO', TObject(3));
  clbPermissoes.Items.AddObject('CADASTRAR FORMA DE PAGAMENTO', TObject(4));
  clbPermissoes.Items.AddObject('FAZER VENDA', TObject(5));
  clbPermissoes.Items.AddObject('FATURAR VENDA', TObject(6));
end;

end.
