unit uVendaDavUI;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.StdCtrls, Vcl.Buttons,
  Vcl.ComCtrls, Data.DB, Vcl.Grids, Vcl.DBGrids, ZAbstractRODataset, uClientesUI,
  ZAbstractDataset, ZDataset,uAppServiceConexao, uFormaPagamentoUI, uFuncionarioUI,
  uProdutoUI,uClienteModel, uUsuarioUI, uUsuarioService,uUsuarioDao,IUsuarioDAO,
  iUsuarioService,uTelaBaseCadastroUI, iVendaService, IProdutoService, uProdutoService, uValidarCampo,
  uException,uFuncionarioModel,iFuncionarioService,uFuncionarioService, iFuncionarioDAO, uFuncionarioDao;
type
  TModoTela = (svIniciada, svCancelada);
  TfrmVendaDav = class(TForm)
    Panel1: TPanel;
    Panel2: TPanel;
    Panel3: TPanel;
    edtNumeroVenda: TEdit;
    Label1: TLabel;
    edtEmisao: TDateTimePicker;
    Label2: TLabel;
    Label3: TLabel;
    edtCliente: TEdit;
    Label6: TLabel;
    Panel4: TPanel;
    Label7: TLabel;
    edtPesquisaProduto: TEdit;
    edtQuantidadeProdutoSelecionado: TEdit;
    Label8: TLabel;
    Label9: TLabel;
    edtValorUnitarioProd: TEdit;
    edtBrutoVenda: TEdit;
    edtDescontoVenda: TEdit;
    edtLiquidoVenda: TEdit;
    Label10: TLabel;
    Label11: TLabel;
    Label12: TLabel;
    edtVendedor: TEdit;
    btnNovaVenda: TBitBtn;
    btnCancelar: TBitBtn;
    btnGravar: TBitBtn;
    Panel5: TPanel;
    Panel6: TPanel;
    painelEstoque: TPanel;
    painelVenda: TPanel;
    dbProdVenda: TDBGrid;
    dbProdEsqtque: TDBGrid;
    Panel7: TPanel;
    Panel8: TPanel;
    DTSProdEstoque: TDataSource;
    QRYProdEstoque: TZQuery;
    DTSProdVenda: TDataSource;
    QRYProdVenda: TZQuery;
    btnSair: TButton;
    procedure FormShow(Sender: TObject);
    procedure edtVendedorClick(Sender: TObject);
    procedure edtClienteClick(Sender: TObject);
    procedure edtPesquisaProdutoChange(Sender: TObject);
    procedure edtPesquisaProdutoKeyPress(Sender: TObject; var Key: Char);
    procedure btnSairClick(Sender: TObject);
    procedure edtNumeroVendaKeyPress(Sender: TObject; var Key: Char);
    procedure btnCancelarClick(Sender: TObject);
    procedure edtQuantidadeProdutoSelecionadoKeyPress(Sender: TObject;
      var Key: Char);
  private
    FModoTela: TModoTela;
    FIdVenda: Integer;
    FCliente: TClienteModel;
    FVendedor: TFuncionarioModel;

    FService: IVendaServiceInterface;
    FProdutoService: IProdutoServiceInterface;
  public
    procedure AlternaPainel(PainelVisivel: TPanel; PainelOculto: TPanel);
    procedure PreencherGrildProdutosEstoque(NomeProd: string);
    procedure AdicionarProdutoSelecionado;
    constructor Create(AOwner: TComponent; AService: IVendaServiceInterface);
    procedure IniciarTela;
    procedure IniciarVenda;
    procedure CancelarVenda;
    procedure GravaVenda;
    procedure ConfigurarEditInativoTela(Ativo: Boolean);
    procedure ControlarButon(Ativo: Boolean);

  end;

var
  frmVendaDav: TfrmVendaDav;
implementation
uses
   iClienteService, uClienteService, IClienteDAO, uClienteDao;

{$R *.dfm}

{ ================== CONSTRUTOR ================== }
constructor TfrmVendaDav.Create(AOwner: TComponent; AService: IVendaServiceInterface);
begin
  inherited Create(AOwner);
  FService:= AService;
end;


{ ================== INICIALIZAÇĂO ================== }
procedure TfrmVendaDav.FormShow(Sender: TObject);
begin
  IniciarTela;
  AlternaPainel(painelEstoque, painelVenda);
end;

procedure TfrmVendaDav.IniciarTela;
begin
  TValidarCampos.ConfigurarEditBloqueado(edtNumeroVenda, True);
  edtNumeroVenda.Text:= '000000';
  TValidarCampos.ConfigurarEditInativo(edtBrutoVenda, false);
  TValidarCampos.ConfigurarEditInativo(edtDescontoVenda, false);
  TValidarCampos.ConfigurarEditInativo(edtLiquidoVenda, false);
  ConfigurarEditInativoTela(false);
  FModoTela:= svCancelada;
  ControlarButon(True);
end;
procedure TfrmVendaDav.ConfigurarEditInativoTela(Ativo: Boolean);
begin
  TValidarCampos.ConfigurarEditInativo(edtValorUnitarioProd, Ativo);
  TValidarCampos.ConfigurarEditInativo(edtQuantidadeProdutoSelecionado, Ativo);
  TValidarCampos.ConfigurarEditInativo(edtPesquisaProduto, Ativo);
  TValidarCampos.ConfigurarEditInativo(edtCliente, Ativo);
  TValidarCampos.ConfigurarEditInativo(edtVendedor, Ativo);
end;

{ ================== CONTROLE DOS BTN ================== }
procedure TfrmVendaDav.ControlarButon(Ativo: Boolean);
begin
  btnNovaVenda.Enabled := Ativo;
  btnCancelar.Enabled :=  not Ativo;
  btnGravar.Enabled :=  not Ativo;
end;

{ ================== EVENTOS ================== }
procedure TfrmVendaDav.edtPesquisaProdutoChange(Sender: TObject);
begin
  if Trim(edtPesquisaProduto.Text).IsEmpty then
  begin
    AlternaPainel(painelVenda, painelEstoque);
    QRYProdEstoque.Close;
    Exit;
  end;
  AlternaPainel(painelEstoque,painelVenda);
  PreencherGrildProdutosEstoque(edtPesquisaProduto.Text);
end;
procedure TfrmVendaDav.edtNumeroVendaKeyPress(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
    begin
      Key := #0;
      IniciarVenda;
    end;
end;
procedure TfrmVendaDav.edtPesquisaProdutoKeyPress(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
  begin
    Key := #0;
    edtQuantidadeProdutoSelecionado.SetFocus;
  end;
end;
procedure TfrmVendaDav.edtQuantidadeProdutoSelecionadoKeyPress(Sender: TObject;
  var Key: Char);
begin
if Key = #13 then
  begin
    Key := #0;
    AdicionarProdutoSelecionado;
  end;
end;

procedure TfrmVendaDav.btnCancelarClick(Sender: TObject);
begin
  CancelarVenda;
end;

{ ================== VENDA ================== }
procedure TfrmVendaDav.IniciarVenda;

begin
  try
   if FModoTela = svCancelada then
   begin
     //fazer o insert no banco e pegar o numero para mostrar na tela
     edtNumeroVenda.Clear;
     FIdVenda := FService.IIniciarVenda(1);
     edtNumeroVenda.Text := IntToStr(FIdVenda);
     FModoTela:= svIniciada;
     ConfigurarEditInativoTela(True);
     ControlarButon(False);
   end;

 except
  on EApp: EAppException do
     ShowMessage(EApp.Message);
  on EInf: EInfraException do
     ShowMessage(EInf.Message);
  on EG: Exception do
      ShowMessage('Falha na operaçăo, tente novamente!'+EG.Message);
  end;
end;
procedure TfrmVendaDav.CancelarVenda;
begin
  try
    if FModoTela = svIniciada then
    begin
      FService.CancelarVenda(FIdVenda);
      ShowMessage('Venda cancelada!');
      IniciarTela;
    end;
  except
  on EApp: EAppException do
     ShowMessage(EApp.Message);
  on EInf: EInfraException do
     ShowMessage(EInf.Message);
  on EG: Exception do
      ShowMessage('Falha na operaçăo, tente novamente!'+EG.Message);
  end;
end;
procedure TfrmVendaDav.GravaVenda;
begin

end;

{ ================== VENDA/ENTIDADE ================== }
procedure TfrmVendaDav.edtVendedorClick(Sender: TObject);
var
  Frm : TfrmCadastroFuncionario;
  Service: IFuncionarioServiceInterface;
  Dao: IFuncionarioDAOO;
begin
  Dao := TFuncionarioDao.Create(AppServiceConexao.getConexao);
  Service := TFuncionarioService.Create(Dao);
  Frm := TfrmCadastroFuncionario.Create(nil,Service);
  try
    Frm.ModoTela := mtSelecao;

    if Frm.ShowModal = mrOk then
    begin
      FVendedor := Frm.GetFuncionario;

      edtVendedor.Text := '';
      edtVendedor.Text := FVendedor
      .Nome;
    end;

  finally
    Frm.Free;
  end;
end;
procedure TfrmVendaDav.edtClienteClick(Sender: TObject);
var
  Frm : TfrmCadastroCliente;
  Service: IClienteServiceInterface;
  Dao: IClienteDAOO;
begin
  Dao := TClienteDao.Create(AppServiceConexao.getConexao);
  Service := TClienteService.Create(Dao);
  Frm := TfrmCadastroCliente.Create(nil, Service);
  try
    Frm.ModoTela := mtSelecao;

    if Frm.ShowModal = mrOk then
    begin
      FCliente := Frm.GetCliente;

      edtCliente.Text := '';
      edtCliente.Text := FCliente.Nome;
      FService.UpdateCliente(FCliente.Id, FIdVenda);
    end;

  finally
    Frm.Free;
  end;

end;
procedure TfrmVendaDav.AdicionarProdutoSelecionado;
var
  IdProduto: Integer;
  Quant: Currency;
begin
  if not QRYProdEstoque.IsEmpty then
  begin
    IdProduto := QRYProdEstoque.FieldByName('ID_PRODUTO').AsInteger;
    Quant:= StrToCurr(edtQuantidadeProdutoSelecionado.Text) ;
    //chamar service de itemVenda
    FService.AdicionarItemVenda(FIdVenda, IdProduto, Quant);
    FService.ListarNaTelaGridVenda(QRYProdVenda, FIdVenda);
    edtPesquisaProduto.Text := '';
    edtPesquisaProduto.SetFocus;
  end;
end;


{ ================== CONSULTA GRID ================== }
procedure TfrmVendaDav.PreencherGrildProdutosEstoque(NomeProd: string);
begin
  FService.ListarNaTelaGridEstoque(QRYProdEstoque, NomeProd);
end;
//---------Manipular tabela que aparece----------------------
procedure TfrmVendaDav.AlternaPainel(PainelVisivel, PainelOculto: TPanel);
begin
   PainelVisivel.Align:= alClient;
   PainelVisivel.Visible:= true;
   PainelOculto.Visible:= False;
end;


procedure TfrmVendaDav.btnSairClick(Sender: TObject);
begin
  if FModoTela = svIniciada then
  begin
    if MessageDlg('Deseja cancelar a venda?', mtConfirmation, [mbYes, mbNo], 0) = mrYes then
    begin
      CancelarVenda;
      Close;
    end;
  end
  else
    Close;
end;

procedure AdicionarQuantidade;
begin

end;

end.
