unit uControlUtils;

interface

uses
  Vcl.StdCtrls, Vcl.Mask, Vcl.ComCtrls, Vcl.Controls;

procedure LimparControles(Parent: TWinControl);
procedure HabilitarControles(Parent: TWinControl; Habilitar: Boolean);

implementation

// LIMPAR CAMPOS
procedure LimparControles(Parent: TWinControl);
var
  i: Integer;
begin
  for i := 0 to Parent.ControlCount - 1 do
  begin
    // TEdit
    if Parent.Controls[i] is TEdit then
      TEdit(Parent.Controls[i]).Clear;

    // TMaskEdit
    if Parent.Controls[i] is TMaskEdit then
      TMaskEdit(Parent.Controls[i]).Clear;

    // ComboBox
    if Parent.Controls[i] is TComboBox then
      TComboBox(Parent.Controls[i]).ItemIndex := -1;

    // DateTimePicker
    if Parent.Controls[i] is TDateTimePicker then
      TDateTimePicker(Parent.Controls[i]).Date := Now;

    // chama recursivo
    if Parent.Controls[i] is TWinControl then
      LimparControles(TWinControl(Parent.Controls[i]));
  end;
end;

// HABILITAR / DESABILITAR
procedure HabilitarControles(Parent: TWinControl; Habilitar: Boolean);
var
  i: Integer;
begin
  for i := 0 to Parent.ControlCount - 1 do
  begin
    // Edit
    if Parent.Controls[i] is TEdit then
      TEdit(Parent.Controls[i]).Enabled := Habilitar;

    // MaskEdit
    if Parent.Controls[i] is TMaskEdit then
      TMaskEdit(Parent.Controls[i]).Enabled := Habilitar;

    // ComboBox
    if Parent.Controls[i] is TComboBox then
      TComboBox(Parent.Controls[i]).Enabled := Habilitar;

    // DateTimePicker
    if Parent.Controls[i] is TDateTimePicker then
      TDateTimePicker(Parent.Controls[i]).Enabled := Habilitar;

    // recursivo
    if Parent.Controls[i] is TWinControl then
      HabilitarControles(TWinControl(Parent.Controls[i]), Habilitar);
  end;
end;

end.
