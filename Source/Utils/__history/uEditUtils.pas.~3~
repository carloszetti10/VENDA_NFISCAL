unit uEditUtils;

interface

uses
  Vcl.StdCtrls, System.SysUtils;

type
  TFormatacao = class
  public
    class procedure AplicarNumero(Edit: TEdit);
    class procedure KeyPressNumero(Sender: TObject; var Key: Char);
    class procedure ExitNumero(Sender: TObject);
  end;

implementation

class procedure TFormatacao.AplicarNumero(Edit: TEdit);
begin
  Edit.OnKeyPress := KeyPressNumero;
  Edit.OnExit := ExitNumero;
end;

class procedure TFormatacao.KeyPressNumero(Sender: TObject; var Key: Char);
begin
  // troca ponto por vírgula
  if Key = '.' then
    Key := ',';

  // só permite número, vírgula e backspace
  if not CharInSet(Key, ['0'..'9', ',', #8]) then
    Key := #0;

  // só uma vírgula
  if (Key = ',') and (Pos(',', (Sender as TEdit).Text) > 0) then
    Key := #0;
end;

class procedure TFormatacao.ExitNumero(Sender: TObject);
var
  E: TEdit;
  V: Double;
begin
  E := Sender as TEdit;

  if Trim(E.Text) = '' then
  begin
    E.Text := '0,00';
    Exit;
  end;

  // garante conversăo correta no padrăo BR
  V := StrToFloat(StringReplace(E.Text, '.', ',', [rfReplaceAll]));

  E.Text := FormatFloat('0.00', V);
end;

end.
